# =============================================================================
# ContextRealm — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in all required values before starting.
#
#   cp .env.example .env
#
# Lines marked [REQUIRED] must be set. Lines marked [OPTIONAL] have safe
# defaults that work for local development.
# =============================================================================


# ─── LiteLLM ─────────────────────────────────────────────────────────────────

# Master API key for LiteLLM proxy. Used by Open WebUI to authenticate.
# Generate a strong random value: openssl rand -hex 32
# [REQUIRED]
LITELLM_MASTER_KEY=sk-change-me


# ─── AI Provider Keys ────────────────────────────────────────────────────────
# Add keys only for providers you want to enable.
# Open WebUI will list all models defined in config/litellm_config.yaml.

# Anthropic (Claude)
# [OPTIONAL — required to use Claude models]
ANTHROPIC_API_KEY=

# OpenAI (GPT-4 / o-series)
# [OPTIONAL — required to use OpenAI models]
OPENAI_API_KEY=

# Google (Gemini)
# [OPTIONAL — required to use Gemini models]
GEMINI_API_KEY=

# xAI (Grok)
# [OPTIONAL — required to use Grok models]
GROK_API_KEY=


# ─── Open WebUI ──────────────────────────────────────────────────────────────

# Secret key for Open WebUI session signing.
# Generate: openssl rand -hex 32
# [REQUIRED]
WEBUI_SECRET_KEY=change-me-webui-secret


# ─── Pipelines ───────────────────────────────────────────────────────────────

# API key for the Pipelines service (set the same value in Open WebUI admin).
# [REQUIRED]
PIPELINES_API_KEY=change-me-pipelines-key


# ─── Mem0 ────────────────────────────────────────────────────────────────────

# Default user ID stored against memories when no authenticated user is present.
# [OPTIONAL]
MEM0_USER_ID=default

# Mem0 upstream version tag to build from (e.g. v2.0.2).
# Pin deliberately — see docker/mem0-server/Dockerfile.
# [REQUIRED — set to a specific tag before building]
MEM0_VERSION=v2.0.2

# JWT signing secret for Mem0's built-in auth (v2.0.2+).
# Generate: openssl rand -base64 48
# [REQUIRED in production — leave blank only if MEM0_AUTH_DISABLED=true]
MEM0_JWT_SECRET=change-me-jwt-secret

# Admin API key for programmatic access (used by the pipeline service).
# Must be at least 16 characters.
# Generate: openssl rand -hex 24
# [REQUIRED in production — leave blank only if MEM0_AUTH_DISABLED=true]
MEM0_ADMIN_API_KEY=change-me-mem0-admin-key

# Disable Mem0 auth for local development only.
# Set to false (or remove) for any internet-facing deployment.
# [OPTIONAL — default: false]
MEM0_AUTH_DISABLED=true

# LLM provider used by Mem0 for memory extraction (default: openai).
# Bundled options: openai, anthropic, gemini
# To use Anthropic: set MEM0_LLM_PROVIDER=anthropic and MEM0_LLM_API_KEY to your key.
# [OPTIONAL — falls back to OPENAI_API_KEY when blank]
MEM0_LLM_PROVIDER=anthropic
MEM0_LLM_API_KEY=

# Embedding vector dimensions reported to pgvector. Must match the dim your
# embedder actually produces, otherwise inserts silently fail with
# `expected N dimensions, not M` and GET /memories returns empty.
#   qwen3-embedding:0.6b  -> 1024
#   text-embedding-3-small -> 1536  (OpenAI default, also Mem0's hard-coded default)
# [OPTIONAL — default 1024 matches the bundled Ollama embedder]
MEM0_EMBEDDING_MODEL_DIMS=1024


# ─── PostgreSQL ──────────────────────────────────────────────────────────────

# Password for the 'postgres' superuser.
# [REQUIRED]
POSTGRES_PASSWORD=change-me-postgres-password

# Database name used by Mem0.
# [OPTIONAL]
POSTGRES_DB=mem0_app


# ─── Neo4j ───────────────────────────────────────────────────────────────────

# Neo4j admin password (username is always 'neo4j').
# [REQUIRED]
NEO4J_PASSWORD=change-me-neo4j-password

# ── Memory limits for Neo4j (critical on a 4 GB VPS) ──
# These settings keep Neo4j within ~1 GB total, leaving headroom for the
# other services. Increase if you have more RAM available.
#
# Maps to neo4j.conf: server.memory.heap.initial_size
NEO4J_server_memory_heap_initial__size=256m
# Maps to neo4j.conf: server.memory.heap.max_size
NEO4J_server_memory_heap_max__size=512m
# Maps to neo4j.conf: server.memory.pagecache.size
NEO4J_server_memory_pagecache_size=256m
# Maps to neo4j.conf: server.memory.off_heap.transaction_max_size
NEO4J_server_memory_off__heap_transaction__max__size=128m


# ─── Ollama ──────────────────────────────────────────────────────────────────

# Override if Ollama is running outside the compose network
# (e.g. on a dedicated VM or droplet in production).
# [OPTIONAL — defaults to http://ollama:11434 inside compose network]
OLLAMA_BASE_URL=http://ollama:11434

# Embedding model. qwen3-embedding:0.6b is fast, accurate, and < 500 MB.
# [OPTIONAL]
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b

# Optional local LLM for fallback / offline use.
# [OPTIONAL]
OLLAMA_LLM_MODEL=qwen2.5:7b


# ─── Realm (multi-realm Helm deployments) ────────────────────────────────────

# Name of this realm instance. Used as a label and subdomain prefix.
# Examples: personal, cyberbright, neotribes
# [OPTIONAL — only used for Helm/K8s deployments]
REALM_NAME=personal


# ─── MCP server ──────────────────────────────────────────────────────────────
# The MCP service exposes the Mem0 store to any MCP-compatible client
# (Claude Desktop, Claude Code, Cursor, scripts) over the Model Context
# Protocol. The compose stack ships a Caddy sidecar that handles TLS
# automatically — set REALM_DOMAIN below to enable Let's Encrypt on a
# public hostname. Leave it blank for local-only use; Caddy serves a
# self-signed cert on https://localhost:8443 in that mode.
#
# Auth is enforced at the MCP layer via the same admin token Mem0 uses.
# Clients send `Authorization: Token <MEM0_ADMIN_API_KEY>` on every request;
# the MCP server forwards the same value to Mem0 so the two layers share
# one gate. With MEM0_AUTH_DISABLED=true (local dev) the value is ignored.
#
# The MCP server itself binds to the internal network only — the only path
# in is through Caddy. See docs/setup.md#mcp-configuration.

# Public hostname for the MCP endpoint. Required for production deployments
# to a VPS so Caddy can request a Let's Encrypt certificate. Examples:
#   mcp.yourdomain.com
#   realm.example.org
# Leave blank for local-only use (Caddy serves a self-signed cert on :8443).
# [REQUIRED for public deployment]
REALM_DOMAIN=
#
